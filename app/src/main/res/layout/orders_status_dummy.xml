<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Step: Placed -->
    <View
        android:id="@+id/stepPlaced"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/blue_img"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp" />

    <TextView
        android:id="@+id/labelPlaced"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Placed"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/stepPlaced"
        app:layout_constraintStart_toStartOf="@id/stepPlaced"
        android:layout_marginTop="4dp" />

    <!-- Line between Placed and Processed -->
    <View
        android:id="@+id/linePlacedToProcessed"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@color/light_gray1"
        app:layout_constraintTop_toTopOf="@id/stepPlaced"
        app:layout_constraintBottom_toBottomOf="@id/stepPlaced"
        app:layout_constraintStart_toEndOf="@id/stepPlaced"
        app:layout_constraintEnd_toStartOf="@id/stepProcessed"
        android:layout_marginHorizontal="4dp" />

    <!-- Step: Sample Collected -->
    <View
        android:id="@+id/stepProcessed"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/grey_img"
        app:layout_constraintTop_toTopOf="@id/stepPlaced"
        app:layout_constraintBottom_toBottomOf="@id/stepPlaced"
        app:layout_constraintStart_toEndOf="@id/stepPlaced"
        app:layout_constraintEnd_toStartOf="@id/stepCompleted"
        app:layout_constraintHorizontal_bias="0.5" />

    <TextView
        android:id="@+id/labelProcessed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sample Collected"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/stepProcessed"
        app:layout_constraintStart_toStartOf="@id/stepProcessed"
        android:layout_marginTop="4dp" />

    <!-- Line between Processed and Completed -->
    <View
        android:id="@+id/lineProcessedToCompleted"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@color/light_gray1"
        app:layout_constraintTop_toTopOf="@id/stepProcessed"
        app:layout_constraintBottom_toBottomOf="@id/stepProcessed"
        app:layout_constraintStart_toEndOf="@id/stepProcessed"
        app:layout_constraintEnd_toStartOf="@id/stepCompleted"
        android:layout_marginHorizontal="4dp" />

    <!-- Step: Reports Sent -->
    <View
        android:id="@+id/stepCompleted"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/grey_img"
        app:layout_constraintTop_toTopOf="@id/stepPlaced"
        app:layout_constraintBottom_toBottomOf="@id/stepPlaced"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp" />

    <TextView
        android:id="@+id/labelCompleted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reports Sent"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/stepCompleted"
        app:layout_constraintEnd_toEndOf="@id/stepCompleted"
        android:layout_marginTop="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
